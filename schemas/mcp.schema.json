{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CodeBot MCP Configuration",
  "description": "Schema for .codebot/mcp.json configuration files",
  "type": "object",
  "required": ["servers"],
  "properties": {
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9_-]+$",
            "description": "Unique server identifier"
          },
          "command": {
            "type": "string",
            "minLength": 1,
            "description": "Executable command to launch the server"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Command-line arguments"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Environment variables for the server process"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
