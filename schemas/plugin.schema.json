{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CodeBot Plugin Manifest",
  "description": "Schema for .codebot/plugins/plugin.json manifest files",
  "type": "object",
  "required": ["name", "version", "hash"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Plugin identifier (alphanumeric, hyphens, underscores)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semver version string"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the plugin .js file, prefixed with sha256:"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional human-readable description"
    },
    "author": {
      "type": "string",
      "maxLength": 128,
      "description": "Optional author name"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["fs", "net", "exec", "env"]
      },
      "description": "Optional declared permissions"
    }
  },
  "additionalProperties": false
}
