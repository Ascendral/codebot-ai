# Local runtime state
CODEAGI_RUNTIME_ROOT=$HOME/CodeAGI/runtime

# Default long-term storage
CODEAGI_LONG_TERM_ROOT=$HOME/CodeAGI/long-term

# Optional external long-term storage on your 4TB drive
# CODEAGI_LONG_TERM_ROOT=/Volumes/CodeAGI-4TB/CodeAGI

# Real tool execution workspace root
CODEAGI_WORKSPACE_ROOT=$HOME/CodeAGI/workspace

# Guarded multi-step execution budget per cycle
CODEAGI_MAX_CYCLE_STEPS=3

# Optional explicit config path
CODEAGI_CONFIG_PATH=
